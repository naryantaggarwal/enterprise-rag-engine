# docker/Dockerfile.frontend
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir streamlit==1.45.1 requests==2.32.3 pandas==2.2.3

COPY frontend/ ./frontend/

# Streamlit config to disable telemetry and set port
RUN mkdir -p ~/.streamlit && cat > ~/.streamlit/config.toml << 'EOF'
[server]
port = 8501
headless = true
enableCORS = false

[browser]
gatherUsageStats = false
EOF

EXPOSE 8501

CMD ["streamlit", "run", "frontend/streamlit_app.py"]
